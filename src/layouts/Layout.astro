---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
}

const { title = 'Arina Makhova' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Arina Makhova — Portfolio" />
    <title>{title}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>
