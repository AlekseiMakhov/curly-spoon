---
interface GalleryItem {
  type: 'image' | 'video';
  src: string;
  cols: 1 | 2 | 3;
  pair?: string;
  pair2?: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="gallery">
  {items.map((item) => {
    if (item.cols === 1) {
      return (
        <div class="gallery__row gallery__row--full">
          {item.type === 'video' ? (
            <video src={item.src} autoplay loop muted playsinline />
          ) : (
            <img src={item.src} alt="" loading="lazy" />
          )}
        </div>
      );
    }

    if (item.cols === 2 && item.pair) {
      return (
        <div class="gallery__row gallery__row--2col">
          <div class="gallery__cell">
            {item.type === 'video' ? (
              <video src={item.src} autoplay loop muted playsinline />
            ) : (
              <img src={item.src} alt="" loading="lazy" />
            )}
          </div>
          <div class="gallery__cell">
            <img src={item.pair} alt="" loading="lazy" />
          </div>
        </div>
      );
    }

    if (item.cols === 3 && item.pair && item.pair2) {
      return (
        <div class="gallery__row gallery__row--3col">
          <div class="gallery__cell">
            <img src={item.src} alt="" loading="lazy" />
          </div>
          <div class="gallery__cell gallery__cell--video">
            <video src={item.pair} autoplay loop muted playsinline />
          </div>
          <div class="gallery__cell gallery__cell--video">
            <video src={item.pair2} autoplay loop muted playsinline />
          </div>
        </div>
      );
    }

    return null;
  })}
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: var(--gap-gallery);
  }

  /* Full-width row */
  .gallery__row--full {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .gallery__row--full img,
  .gallery__row--full video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 2-column row */
  .gallery__row--2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap-gallery);
  }

  .gallery__cell {
    overflow: hidden;
  }

  .gallery__row--2col .gallery__cell {
    aspect-ratio: 3 / 4;
  }

  .gallery__row--2col img,
  .gallery__row--2col video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 3-column row — left is image, right two are 9:16 videos */
  .gallery__row--3col {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--gap-gallery);
    align-items: end;
  }

  .gallery__row--3col .gallery__cell {
    aspect-ratio: 3 / 4;
  }

  .gallery__row--3col .gallery__cell--video {
    aspect-ratio: 9 / 16;
  }

  .gallery__row--3col img,
  .gallery__row--3col video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .gallery {
      gap: 20px;
    }

    .gallery__row--2col {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .gallery__row--3col {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    .gallery__row--full {
      aspect-ratio: 4 / 3;
    }
  }
</style>
