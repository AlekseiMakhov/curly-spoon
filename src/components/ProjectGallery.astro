---
interface GalleryItem {
  type: 'image' | 'video';
  src: string;
  cols: 1 | 2 | 3;
  pair?: string;
  pair2?: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
---

<div class="gallery">
  {items.map((item) => {
    if (item.cols === 1) {
      return (
        <div class="gallery__row gallery__row--full">
          {item.type === 'video' ? (
            <video src={withBase(item.src)} autoplay loop muted playsinline />
          ) : (
            <img src={withBase(item.src)} alt="" loading="lazy" />
          )}
        </div>
      );
    }

    if (item.cols === 2 && item.pair) {
      return (
        <div class="gallery__row gallery__row--2col">
          <div class="gallery__cell">
            {item.type === 'video' ? (
              <video src={withBase(item.src)} autoplay loop muted playsinline />
            ) : (
              <img src={withBase(item.src)} alt="" loading="lazy" />
            )}
          </div>
          <div class="gallery__cell">
            <img src={withBase(item.pair)} alt="" loading="lazy" />
          </div>
        </div>
      );
    }

    if (item.cols === 3 && item.pair && item.pair2) {
      return (
        <div class="gallery__row gallery__row--3col">
          <div class="gallery__cell">
            <img src={withBase(item.src)} alt="" loading="lazy" />
          </div>
          <div class="gallery__cell gallery__cell--video">
            <video src={withBase(item.pair)} autoplay loop muted playsinline />
          </div>
          <div class="gallery__cell gallery__cell--video">
            <video src={withBase(item.pair2)} autoplay loop muted playsinline />
          </div>
        </div>
      );
    }

    return null;
  })}
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: var(--gap-gallery);
  }

  /* Full-width row */
  .gallery__row--full {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .gallery__row--full img,
  .gallery__row--full video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Rows sit on the layout grid (12 cols desktop / 6 cols ≤900px) */
  .gallery__row--2col,
  .gallery__row--3col {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
    column-gap: var(--gap-gallery);
  }

  .gallery__cell {
    overflow: hidden;
  }

  /* 2-column row — two equal halves (6 of 12 cols, or 3 of 6) */
  .gallery__row--2col .gallery__cell {
    grid-column: span 6;
    aspect-ratio: 3 / 4;
  }

  .gallery__row--2col img,
  .gallery__row--2col video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 3-column row — left is image, right two are 9:16 videos (4 of 12 cols, or 2 of 6) */
  .gallery__row--3col {
    align-items: end;
  }

  .gallery__row--3col .gallery__cell {
    grid-column: span 4;
    aspect-ratio: 3 / 4;
  }

  .gallery__row--3col .gallery__cell--video {
    aspect-ratio: 9 / 16;
  }

  .gallery__row--3col img,
  .gallery__row--3col video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    /* 6-column grid: halves span 3, thirds span 2 */
    .gallery__row--2col .gallery__cell {
      grid-column: span 3;
    }

    .gallery__row--3col .gallery__cell {
      grid-column: span 2;
    }

    .gallery__row--full {
      aspect-ratio: 4 / 3;
    }
  }
</style>
