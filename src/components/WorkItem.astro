---
// One block of the hover marquee. `type` is 'image' | 'video' | 'text' | 'placeholder'.
// image/video need `src`; cells default to a 3:4 box — set `ratio` (e.g. "4/5",
// "9/16") or `width` (e.g. "320px") to override. text takes `value`, or falls back
// to the description tagline. placeholder is an empty skeleton cell (no media yet).
interface MarqueeBlock {
  type: string;
  src?: string;
  value?: string;
  ratio?: string;
  width?: string;
}

interface Props {
  slug: string;
  index: string;
  title: string;
  cover: string;
  description: string;
  marquee: MarqueeBlock[];
}

const { slug, index, title, cover, description, marquee } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
const tagline = description.split('. ')[0] + '.';

// Optional per-block sizing -> inline style; empty string when the block sizes naturally.
const mediaStyle = (b: MarqueeBlock) =>
  [b.ratio && `aspect-ratio:${b.ratio}`, b.width && `width:${b.width}`].filter(Boolean).join(';');
---

<a href={withBase(`/works/${slug}`)} class="work-item">
  <div class="work-item__content">
    <span class="work-item__index">{index}</span>
    <h2 class="work-item__title">{title}</h2>
    <img class="work-item__thumb" src={withBase(cover)} alt="" loading="lazy" />
  </div>

  <div class="work-item__marquee" aria-hidden="true">
    <div class="work-item__marquee-inner">
      {[0, 1].map(() => (
        <div class="work-item__marquee-track">
          <span class="work-item__marquee-name">
            <span class="work-item__marquee-index">{index}</span>
            <span class="work-item__marquee-heading">{title}</span>
          </span>
          {marquee.map((block) => (
            block.type === 'video' ? (
              <video class="work-item__marquee-media" src={withBase(block.src!)} style={mediaStyle(block)} loop muted playsinline preload="auto"></video>
            ) : block.type === 'text' ? (
              <p class="work-item__marquee-desc">{block.value ?? tagline}</p>
            ) : block.type === 'placeholder' ? (
              <div class="work-item__marquee-media work-item__marquee-media--skeleton" style={mediaStyle(block)} aria-hidden="true"></div>
            ) : (
              <img class="work-item__marquee-media" src={withBase(block.src!)} style={mediaStyle(block)} alt="" loading="eager" />
            )
          ))}
        </div>
      ))}
    </div>
  </div>
</a>

<script>
  // Marquee scroll (rAF, constant px/sec) + video playback limited to the clip under
  // the cursor — playing several previews at once stuttered the idle scroll.
  const SPEED = 200; // pixels per second — single knob for the marquee speed

  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>('.work-item').forEach((item) => {
      const marquee = item.querySelector<HTMLElement>('.work-item__marquee');
      const inner = item.querySelector<HTMLElement>('.work-item__marquee-inner');
      const track = item.querySelector('.work-item__marquee-track');
      if (!marquee || !inner || !track) return;

      // Scroll the strip (rAF; constant px/sec; wrap at one track-width = seamless).
      let rafId = 0, x = 0, prev = 0, startedAt = 0, wrap = 0;
      const frame = (t: number) => {
        if (!startedAt) { startedAt = t; prev = t; }
        const dt = Math.min((t - prev) / 1000, 0.05); // cap so a stalled frame can't jump the strip
        prev = t;
        if (!wrap) wrap = track.getBoundingClientRect().width;
        if (t - startedAt >= 100) { x += SPEED * dt; if (wrap) x %= wrap; }
        inner.style.transform = `translateX(${-x}px)`;
        rafId = requestAnimationFrame(frame);
      };

      // Play ONLY the clip directly under the cursor — even one always-playing clip still
      // stutters the idle scroll, so default to nothing playing (smooth) and bring a clip
      // to life only while the pointer is over it (re-checked as the strip scrolls under a
      // still cursor).
      const videos = [...item.querySelectorAll<HTMLVideoElement>('.work-item__marquee video')];
      let hovered = false, mx = -1, my = -1, pickTimer = 0;
      const playUnderCursor = () => {
        if (!hovered) return;
        let target: HTMLVideoElement | null = null;
        for (const v of videos) {
          const r = v.getBoundingClientRect();
          if (mx >= r.left && mx <= r.right && my >= r.top && my <= r.bottom) { target = v; break; }
        }
        for (const v of videos) {
          if (v === target) { const p = v.play(); if (p) p.catch(() => {}); } else v.pause();
        }
      };

      item.addEventListener('pointermove', (e) => { mx = e.clientX; my = e.clientY; playUnderCursor(); });
      item.addEventListener('pointerenter', (e) => {
        hovered = true; mx = e.clientX; my = e.clientY;
        if (!rafId) { x = 0; prev = 0; startedAt = 0; wrap = track.getBoundingClientRect().width; rafId = requestAnimationFrame(frame); }
        pickTimer = window.setInterval(playUnderCursor, 80); // re-check as the strip scrolls under a still cursor
        playUnderCursor();
      });
      item.addEventListener('pointerleave', () => {
        hovered = false;
        clearInterval(pickTimer);
        videos.forEach((v) => v.pause());
        cancelAnimationFrame(rafId); rafId = 0;
        inner.style.transform = '';
      });
    });
  }
</script>

<style>
  .work-item {
    display: block;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background-color 0.25s;
    /* full-bleed separator above each project (and between them) */
    border-top: 1.5px solid var(--color-text);
  }

  .work-item:hover {
    background-color: var(--color-text);
  }

  /* Static index + title aligned to the grid; the marquee stays full-bleed. */
  .work-item__content {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    height: 320px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .work-item__index {
    font-family: var(--font-mono);
    font-weight: 300;
    font-size: 20px;
    line-height: 1.5;
    margin-top: 82px;
    transition: opacity 0.15s;
  }

  .work-item__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 250px;
    line-height: 0.8;
    margin-top: 30px;
    text-transform: lowercase;
    transition: opacity 0.15s;
  }

  .work-item:hover .work-item__index,
  .work-item:hover .work-item__title {
    opacity: 0;
  }

  .work-item__thumb {
    display: none;
  }

  /* Marquee overlay */
  .work-item__marquee {
    position: absolute;
    inset: 0;
    padding-block: 18px;
    overflow: hidden;
    display: none;
    pointer-events: none;
    container-type: inline-size; /* 100cqw = row width (no scrollbar), matches the .container math */
  }

  .work-item:hover .work-item__marquee {
    display: block;
  }

  /* Two identical tracks side by side, scrolling in lockstep for a seamless loop */
  .work-item__marquee-inner {
    display: flex;
    height: 100%;
  }

  .work-item__marquee-track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    height: 100%;
    gap: var(--gap-gallery);
    /* Leading gap = page text's left edge (same math as .container; 100cqw = row width).
       It lives INSIDE the looped period, so it recurs identically at every seam ->
       the loop is flash-free, and the first item starts exactly on the page grid. */
    padding-left: max(var(--page-padding), calc((100cqw - var(--grid-max)) / 2 + var(--page-padding)));
    /* track 2 sits flush after track 1; the script wraps at one track-width, so the
       loop is seamless. */
  }

  /* Promote the moving strip while hovered so its per-frame transform (set by the
     script) composites on the GPU. */
  .work-item:hover .work-item__marquee-inner {
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-item__marquee-media--skeleton {
      animation: none;
    }
  }

  /* Number + name pair — same offsets as the static .work-item__content */
  .work-item__marquee-name {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: -18px; /* cancel .work-item__marquee padding-block so offsets are from the row top */
  }

  .work-item__marquee-index {
    font-family: var(--font-mono);
    font-weight: 300;
    font-size: 20px;
    line-height: 1.5;
    margin-top: 82px;
    color: var(--color-bg);
    flex-shrink: 0;
  }

  .work-item__marquee-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 250px;
    line-height: 0.8;
    margin-top: 30px;
    color: var(--color-bg);
    flex-shrink: 0;
    white-space: nowrap;
    text-transform: lowercase;
  }

  .work-item__marquee-media {
    display: block;
    height: 100%;
    /* Reserve each cell's size up front: a still-loading or missing cell stays a
       sized box (not 0-width), and the strip no longer reflows as videos pop in.
       3:4 matches the optimized thumbnails; a block's ratio/width overrides it. */
    aspect-ratio: 3 / 4;
    width: auto;
    object-fit: cover;
    flex-shrink: 0;
    /* Placeholder colour behind the media; the image/video paints over it once
       loaded, so a still-loading cell reads as a plain grey box. */
    background-color: var(--color-placeholder);
  }

  /* Empty placeholder cells (a project with no media yet) get an animated skeleton
     sheen. Scoped to placeholders so the scrolling video cells stay paint-cheap. */
  .work-item__marquee-media--skeleton {
    background-image: linear-gradient(100deg, transparent 40%, rgba(255, 255, 255, 0.07) 50%, transparent 60%);
    background-repeat: no-repeat;
    background-size: 200% 100%;
    animation: marquee-skeleton 1.4s linear infinite;
  }

  @keyframes marquee-skeleton {
    from { background-position: 150% 0; }
    to   { background-position: -150% 0; }
  }

  .work-item__marquee-desc {
    font-family: var(--font-mono);
    font-size: 18px;
    line-height: 1.5;
    width: 460px;
    /* 70px clear on each side: 40px track gap + 30px margin */
    margin-inline: 30px;
    color: var(--color-bg);
    flex-shrink: 0;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .work-item__content {
      height: auto;
      display: grid;
      grid-template-columns: 1fr 100px;
      grid-template-rows: auto auto;
      align-items: center;
      gap: 0 12px;
    }

    .work-item:hover {
      background-color: transparent;
    }

    .work-item:hover .work-item__index,
    .work-item:hover .work-item__title {
      opacity: 1;
    }

    .work-item__index {
      font-size: 20px;
      margin-top: 0;
      grid-column: 1;
      grid-row: 1;
    }

    .work-item__title {
      font-size: clamp(48px, 14vw, 60px);
      line-height: 1;
      margin-top: 0;
      grid-column: 1;
      grid-row: 2;
    }

    .work-item__thumb {
      display: block;
      width: 100px;
      height: 100px;
      object-fit: cover;
      grid-column: 2;
      grid-row: 1 / 3;
    }

    .work-item__marquee {
      display: none !important;
    }
  }
</style>
