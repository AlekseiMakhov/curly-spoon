---
// Per-project image swiper for the projects list on tablet / mobile (replaces the
// old scroll carousel). Three cards are visible: an enlarged active card in the
// centre with its two neighbours ~75% under it (25% peek). No arrows; swipe only
// on touchscreens.
//
// The transition is a CROSS-MORPH, not a linear drag-follow: on swipe the active
// card shrinks + fades as it slides to a neighbour slot, while the next neighbour
// grows + fades in as it slides to the centre. Cards are positioned by role and
// CSS-transition between roles when the active index changes. Multi-instance safe.
interface Props {
  images: string[];
  name: string;
  loop?: boolean;
  /** Eagerly load the lead (active) image — set on the first, above-the-fold row for LCP. */
  priority?: boolean;
}

const { images, name, loop = true, priority = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (p: string) => (/^https?:\/\//.test(p) ? p : `${base}${p}`);
const count = images.length;
---

<div class="pswiper" data-pswiper data-loop={String(loop)}>
  <div class="pswiper__viewport">
    {images.map((src, i) => (
      <div
        class:list={['pswiper__slide', { 'is-active': i === 0 }]}
        aria-roledescription="slide"
        aria-label={`${name} — ${i + 1} of ${count}`}
        aria-current={i === 0 ? 'true' : 'false'}
        data-pswiper-slide
      >
        <img
          class="pswiper__img"
          src={withBase(src)}
          width="493"
          height="660"
          alt={`${name} — ${i + 1}`}
          loading={priority && i === 0 ? 'eager' : 'lazy'}
          fetchpriority={priority && i === 0 ? 'high' : 'auto'}
          decoding="async"
          draggable={false}
        />
      </div>
    ))}
  </div>
</div>

<script>
  const SCALE = 280 / 330; // inactive card height (280) relative to active (330)
  const SWIPE_MIN = 40;    // px — horizontal distance that counts as a swipe
  const AUTO_MS = 1000;    // mobile auto-advance interval (~1/s)
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => matchMedia('(max-width: 899px)').matches; // mobile, not tablet

  const instances: { viewport: HTMLElement; advance: () => void; ratio: number }[] = [];

  document.querySelectorAll<HTMLElement>('[data-pswiper]').forEach((root) => {
    const viewport = root.querySelector<HTMLElement>('.pswiper__viewport');
    if (!viewport) return;
    const slides = [...root.querySelectorAll<HTMLElement>('[data-pswiper-slide]')];
    const n = slides.length;
    if (!n) return;
    const loop = root.dataset.loop === 'true';
    let active = 0;

    const DURATION = 450; // keep in sync with the transform transition (ms)

    const distOf = (j: number, a: number) => {
      let d = j - a;
      if (loop) { if (d > n / 2) d -= n; if (d < -n / 2) d += n; }
      return d;
    };

    // Motion: positions + scale. Applied immediately so the cards travel the whole time.
    const applyMotion = (a: number) => {
      const w = slides[a].offsetWidth || 0;
      const offset = (w * (2 - SCALE)) / 4; // neighbour 75% under the active card
      slides.forEach((s, j) => {
        const d = distOf(j, a);
        s.style.transform = `translate(-50%, -50%) translateX(${d * offset}px) scale(${d === 0 ? 1 : SCALE})`;
      });
    };

    // Focus: which card is lit + on top. Swapped at the MIDDLE of the animation.
    const applyFocus = (a: number) => {
      slides.forEach((s, j) => {
        const d = distOf(j, a);
        const ad = Math.abs(d);
        const isActive = d === 0;
        s.classList.toggle('is-active', isActive);
        s.setAttribute('aria-current', isActive ? 'true' : 'false');
        s.style.zIndex = String(10 - ad); // stay below the fixed header (z-index 100)
        s.style.opacity = isActive ? '1' : ad === 1 ? '0.5' : '0';
      });
    };

    const render = () => { applyMotion(active); applyFocus(active); };

    let focusTimer = 0;
    const go = (dir: number) => {
      active = loop ? (active + dir + n) % n : Math.min(n - 1, Math.max(0, active + dir));
      applyMotion(active);                                            // start travelling now
      clearTimeout(focusTimer);
      focusTimer = window.setTimeout(() => applyFocus(active), DURATION / 2); // focus flips mid-way
    };

    // Swipe — touch only; no movement during the drag, the morph plays on release.
    // `swiped` suppresses the wrapping <a>'s click so a swipe browses instead of
    // opening the project; a plain tap (no swipe) still navigates.
    let startX = 0, startY = 0, tracking = false, swiped = false;
    const link = root.closest('a');
    viewport.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX; startY = e.touches[0].clientY;
      tracking = true; swiped = false;
    }, { passive: true });
    viewport.addEventListener('touchend', (e) => {
      if (!tracking) return;
      tracking = false;
      const dx = e.changedTouches[0].clientX - startX;
      const dy = e.changedTouches[0].clientY - startY;
      if (Math.abs(dx) >= SWIPE_MIN && Math.abs(dx) > Math.abs(dy)) { swiped = true; go(dx < 0 ? 1 : -1); }
    }, { passive: true });
    link?.addEventListener('click', (e) => {
      if (swiped) { e.preventDefault(); e.stopPropagation(); }
    }, true);

    render();
    // card width is fixed, but the swiper may go from hidden (desktop) to shown on resize
    window.addEventListener('resize', render);
    instances.push({ viewport, advance: () => go(1), ratio: 0 });
  });

  // Mobile only: auto-advance the single most-visible swiper (~1/s) — like video
  // autoplay when you scroll to it. Only one project ever animates at a time.
  if (!reduce && instances.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        const inst = instances.find((i) => i.viewport === e.target);
        if (inst) inst.ratio = e.isIntersecting ? e.intersectionRatio : 0;
      }
    }, { threshold: [0, 0.25, 0.5, 0.75, 1] });
    instances.forEach((i) => io.observe(i.viewport));
    setInterval(() => {
      if (!isMobile()) return;
      const best = instances.filter((i) => i.ratio >= 0.5).sort((a, b) => b.ratio - a.ratio)[0];
      if (best) best.advance();
    }, AUTO_MS);
  }
</script>

<style>
  .pswiper {
    --ps-h-active: 20.625rem; /* active card height (background cards are scaled to 280) */
    width: 100%;
  }

  .pswiper__viewport {
    /* exactly the active card + its two 25%-peeking neighbours; nothing else shows */
    position: relative;
    height: var(--ps-h-active);
    max-width: 22.5rem;
    margin-inline: auto;
    overflow: hidden;
    touch-action: pan-y; /* let the page scroll vertically; horizontal = our swipe */
  }

  /* Cards are stacked & positioned by role (JS); they morph between roles on swipe. */
  .pswiper__slide {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%); /* base; JS sets the role transform */
    transform-origin: center;
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1), opacity 0.25s ease;
    will-change: transform, opacity;
  }

  .pswiper__img {
    display: block;
    height: var(--ps-h-active);
    width: auto;
    aspect-ratio: 493 / 660;
    object-fit: cover;
    background-color: var(--color-placeholder);
    -webkit-user-drag: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .pswiper__slide {
      transition: none;
    }
  }
</style>
