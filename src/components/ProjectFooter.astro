---
import ContactInfo from './ContactInfo.astro';

interface Props {
  nextSlug: string;
  nextTitle: string;
}

const { nextSlug, nextTitle } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="project__footer">
  <a href={`${base}/projects/${nextSlug}`} class="footer__next">
    <span class="footer__next-label">next</span>
    <span class="footer__next-title hover-underline">{nextTitle} <span class="footer__arrow">→</span></span>
  </a>

  <div class="footer__info">
    <ContactInfo label="Contact me" />
  </div>
</footer>

<style>
  /* Project footer: next-link (left, col 1) · info = contact + socials (right) */
  .project__footer {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding: 6.25rem var(--page-padding) 0; /* top = gap to title; height set by min-height */
    min-height: 16.875rem;
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
    column-gap: var(--grid-gutter);
    align-items: start;
    align-content: start;
  }

  /* Next-project link: small "next" label hangs left of the big title */
  .footer__next {
    grid-column: 1 / 7;
    position: relative;
    padding-left: 4.6875rem;
  }

  .footer__next-label {
    position: absolute;
    left: 0;
    top: 2rem;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 1.25rem;
    line-height: 1.5;
  }

  .footer__next-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 6.25rem;
    line-height: 1.2;
    text-transform: lowercase;
    white-space: nowrap;
  }

  /* Underline animates when hovering anywhere on the link (incl. the "next" label) */
  .footer__next:hover .footer__next-title::after {
    transform: scaleX(1);
  }

  .footer__arrow {
    font-size: 0.8em;
  }

  /* contact (col 7) + socials (right), bottom-aligned — layout passed to ContactInfo via vars */
  .footer__info {
    grid-column: 7 / -1;
    margin-top: 2.3125rem;
    font-size: 1.25rem;
    --ci-direction: row;
    --ci-justify: space-between;
    --ci-align: flex-end;
    --ci-gap: var(--grid-gutter);
    --ci-socials-gap: 1.875rem;
  }

  /* ≤1919 — Figma 1440 */
  @media (max-width: 1919px) {
    .project__footer {
      min-height: 14.0625rem;
      padding-top: 3.125rem;
    }

    .footer__next-title {
      font-size: 5rem;
    }

    .footer__next-label {
      top: 2.8125rem;
    }

    .footer__info {
      margin-top: 3.125rem;
    }
  }

  /* ≤1439 — Figma 1024: info (contact + socials) becomes a right-aligned column */
  @media (max-width: 1439px) {
    .project__footer {
      min-height: 14.375rem;
      padding-top: 3.625rem;
    }

    .footer__next-title {
      font-size: 4.375rem;
    }

    .footer__next-label {
      top: 1.375rem;
    }

    .footer__info {
      grid-column: 8 / -1;
      margin-top: 1.375rem;
      --ci-direction: column;
      --ci-align: flex-start;
      --ci-gap: 0.3125rem;
    }
  }

  /* ≤1023 — Figma 874 */
  @media (max-width: 1023px) {
    .project__footer {
      min-height: 10.1875rem;
      padding-top: 2.5rem;
    }

    .footer__next-title {
      font-size: 3.75rem;
    }

    .footer__next-label {
      top: 1.1875rem;
    }

    .footer__info {
      margin-top: 1.25rem;
    }

    .footer__next-label,
    .footer__info {
      font-size: 0.875rem;
    }
  }

  /* ≤900 — footer stacks vertically; "next" sits above the title */
  @media (max-width: 900px) {
    .project__footer {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2.5rem;
      min-height: 0;
      padding-top: 3.75rem;
      padding-bottom: 3.75rem;
    }

    .footer__next {
      display: flex;
      flex-direction: column;
      padding-left: 0;
    }

    .footer__next-label {
      position: static;
      top: auto;
    }

    .footer__info {
      grid-column: auto;
      margin-top: 0;
      --ci-direction: column;
      --ci-align: flex-start;
      --ci-gap: 0.3125rem;
    }
  }
</style>
