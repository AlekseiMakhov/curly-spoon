---
// Reusable site footer (About and other non-project pages). Three blocks:
//   1 — credits, 2 — email, 3 — social links.
// Desktop: aligned to the grid (block 1 → col 1, block 2 → col 7, block 3 pinned right).
// Tablet (≤1439): the three blocks spread with space-between.
// Vertical mobile (≤768): stacked — block 2, block 3 (5px apart), then block 1 (50px below).
import { EMAIL, SOCIALS } from '../consts';

interface Props {
  credits?: string[];
}

const { credits = ['Arina Makhova', '©2026'] } = Astro.props;
---

<footer class="site-footer">
  <div class="site-footer__block site-footer__credits">
    {credits.map((line) => <span>{line}</span>)}
  </div>

  <div class="site-footer__block site-footer__email">
    <span>Contact me</span>
    <a href={`mailto:${EMAIL}`} class="hover-underline">{EMAIL}</a>
  </div>

  <div class="site-footer__block site-footer__links">
    {SOCIALS.map((s) => (
      <a href={s.href} class="hover-underline" aria-label={s.name} target="_blank" rel="noopener noreferrer">{s.label}</a>
    ))}
  </div>
</footer>

<style>
  /* Desktop — three blocks on the 12-col grid */
  .site-footer {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    padding-bottom: 68px;
    min-height: 210px;
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
    column-gap: var(--grid-gutter);
    align-items: end;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.5;
  }

  .site-footer__block {
    display: flex;
    flex-direction: column;
  }

  .site-footer__credits {
    grid-column: 1 / 7;
  }

  .site-footer__email {
    grid-column: 7 / 11;
  }

  /* keep the hover underline only as wide as the email text, not the whole block */
  .site-footer__email a {
    align-self: flex-start;
  }

  .site-footer__links {
    grid-column: 11 / -1;
    justify-self: end;
    flex-direction: row;
    gap: 30px;
  }

  /* Tablet — even spacing between the three blocks */
  @media (max-width: 1439px) {
    .site-footer {
      min-height: 165px;
      padding-bottom: 50px;
      display: flex;
      justify-content: space-between;
      gap: var(--grid-gutter);
    }
  }

  /* Vertical mobile — stack: email, links (5px), then credits (50px below) */
  @media (max-width: 768px) {
    .site-footer {
      min-height: 315px;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      gap: 0;
    }

    .site-footer__email {
      order: 1;
    }

    .site-footer__links {
      order: 2;
      margin-top: 5px;
      justify-self: start;
    }

    .site-footer__credits {
      order: 3;
      margin-top: 50px;
    }
  }
</style>
