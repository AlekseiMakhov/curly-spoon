---
import { EMAIL, SOCIALS } from '../consts';

interface Props {
  label?: string;
}

const { label } = Astro.props;
---

<div class="contact-info">
  <div class="contact-info__contact">
    {label && <span class="contact-info__label">{label}</span>}
    <a href={`mailto:${EMAIL}`} class="contact-info__email hover-underline">{EMAIL}</a>
  </div>

  <div class="contact-info__socials">
    {SOCIALS.map((s) => (
      <a href={s.href} class="contact-info__social hover-underline" aria-label={s.name} target="_blank" rel="noopener noreferrer">{s.label}</a>
    ))}
  </div>
</div>

<style>
  /* Layout is driven by the parent via inherited custom properties + font-size,
     so this works as a column (menu / About) or a bottom-aligned row (project footer). */
  .contact-info {
    display: flex;
    flex-direction: var(--ci-direction, column);
    justify-content: var(--ci-justify, flex-start);
    align-items: var(--ci-align, flex-start);
    gap: var(--ci-gap, 0.3125rem);
    font-family: var(--font-mono);
    font-weight: 400;
    line-height: 1.5;
  }

  .contact-info__contact {
    display: flex;
    flex-direction: column;
    gap: 0.3125rem;
  }

  .contact-info__socials {
    display: flex;
    gap: var(--ci-socials-gap, 1.25rem);
  }

  /* Hover effect comes from the global `.hover-underline` utility.
     Keep links shrink-to-content so the underline matches the text width. */
  .contact-info__email,
  .contact-info__social {
    align-self: flex-start;
  }
</style>
