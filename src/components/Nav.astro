---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;
const isHome = currentPath === `${base}/` || currentPath === base;
const isAbout = currentPath.startsWith(`${base}/about`);
---

<header class="nav">
  <div class="nav__inner">
    <a href={`${base}/`} class="nav__logo">Arina Makhova</a>

    <nav class="nav__links" aria-label="Main navigation">
      <a href={`${base}/`} class:list={['nav__link', 'nav__link--projects', { active: isHome }]}>Projects</a>
      <a href={`${base}/about`} class:list={['nav__link', 'nav__link--about', { active: isAbout }]}>About</a>
    </nav>

    <button class="nav__burger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav__mobile-menu" aria-hidden="true">
    <button class="nav__mobile-close" aria-label="Close menu">
      <span></span>
      <span></span>
    </button>

    <nav class="nav__mobile-nav" aria-label="Mobile navigation">
      <a href={`${base}/`} class="nav__mobile-link">Projects</a>
      <a href={`${base}/about`} class="nav__mobile-link">About</a>
    </nav>

    <div class="nav__mobile-contact">
      <span class="nav__mobile-contact-label">Contact me :</span>
      <a href="mailto:arina.makhova@gmail.com" class="nav__mobile-contact-email">arina.makhova@gmail.com</a>
      <div class="nav__mobile-socials">
        <a href="#" class="nav__mobile-social" aria-label="Instagram">IG</a>
        <a href="#" class="nav__mobile-social" aria-label="Behance">BE</a>
        <a href="#" class="nav__mobile-social" aria-label="Facebook">FB</a>
        <a href="#" class="nav__mobile-social" aria-label="LinkedIn">LI</a>
      </div>
    </div>
  </div>
</header>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement;
  const mobileMenu = document.querySelector('.nav__mobile-menu') as HTMLElement;
  const closeBtn = document.querySelector('.nav__mobile-close') as HTMLButtonElement;

  function openMenu() {
    mobileMenu.classList.add('is-open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu.classList.remove('is-open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--color-bg);
  }

  .nav__inner {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
    column-gap: var(--grid-gutter);
    align-items: center;
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    height: var(--nav-height);
  }

  .nav__logo {
    grid-column: 1;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.5;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* Links sit directly on the header grid */
  .nav__links {
    display: contents;
  }

  .nav__link {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.5;
    letter-spacing: 0.02em;
    opacity: 0.4;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .nav__link--projects {
    grid-column: 4;
  }

  .nav__link--about {
    grid-column: 12;
    justify-self: end;
  }

  .nav__link:hover,
  .nav__link.active {
    opacity: 1;
  }

  .nav__burger {
    grid-column: 6;
    justify-self: end;
    display: none;
    width: 30px;
    height: 30px;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav__burger span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
  }

  /* Mobile menu overlay */
  .nav__mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background-color: var(--color-bg);
    z-index: 200;
    flex-direction: column;
    justify-content: space-between;
    padding: 70px 20px 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .nav__mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* Close icon — 30×30 X */
  .nav__mobile-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav__mobile-close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 30px;
    height: 2px;
    background-color: var(--color-text);
  }

  .nav__mobile-close span:first-child {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .nav__mobile-close span:last-child {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  /* Top links */
  .nav__mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .nav__mobile-link {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.5;
  }

  /* Bottom contact block */
  .nav__mobile-contact {
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
  }

  .nav__mobile-socials {
    display: flex;
    gap: 20px;
  }

  @media (max-width: 900px) {
    .nav__links {
      display: none;
    }

    .nav__burger {
      display: flex;
    }

    .nav__mobile-menu {
      display: flex;
    }
  }
</style>
