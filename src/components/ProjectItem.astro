---
// One project row on the projects list.
//  - ≥1440px (desktop): hover marquee (the scrolling strip below).
//  - <1440px (tablet/mobile): no hover — show the title (footer-style, with a "→")
//    plus a per-project image swiper (ProjectSwiper). <900px stacks it under the title.
//
// `marquee` blocks (desktop strip): image/video need `src`; cells default to 3:4. text
// takes `value` (falls back to the description tagline). placeholder = empty skeleton.
// `swiper` is the list of tablet/mobile swiper image paths.
import ProjectSwiper from './ProjectSwiper.astro';

interface MarqueeBlock {
  type: string;
  src?: string;
  value?: string;
  ratio?: string;
  width?: string;
}

interface Props {
  slug: string;
  index: string;
  title: string;
  description: string;
  marquee: MarqueeBlock[];
  swiper: string[];
  /** First row above the fold — eagerly load its lead swiper image for a faster LCP. */
  priority?: boolean;
}

const { slug, index, title, description, marquee, swiper, priority = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
const tagline = description.split('. ')[0] + '.';

// Optional per-block sizing -> inline style; empty string when the block sizes naturally.
const mediaStyle = (b: MarqueeBlock) =>
  [b.ratio && `aspect-ratio:${b.ratio}`, b.width && `width:${b.width}`].filter(Boolean).join(';');
---

<a href={withBase(`/projects/${slug}`)} class="project-item">
  <div class="project-item__content">
    <div class="project-item__head">
      <span class="project-item__index">{index}</span>
      <h2 class="project-item__title">{title}</h2>
    </div>

    {/* Tablet/mobile swiper — replaces the hover marquee below 1440px */}
    <div class="project-item__media">
      <ProjectSwiper images={swiper} name={title} priority={priority} />
      <span class="project-item__cta">View project <span aria-hidden="true">→</span></span>
    </div>
  </div>

  <div class="project-item__marquee" aria-hidden="true">
    <div class="project-item__marquee-inner">
      {[0, 1].map(() => (
        <div class="project-item__marquee-track">
          <span class="project-item__marquee-name">
            <span class="project-item__marquee-index">{index}</span>
            <span class="project-item__marquee-heading">{title}</span>
          </span>
          {marquee.map((block) => (
            block.type === 'video' ? (
              <video class="project-item__marquee-media" src={withBase(block.src!)} style={mediaStyle(block)} loop muted playsinline preload="none"></video>
            ) : block.type === 'text' ? (
              <p class="project-item__marquee-desc">{block.value ?? tagline}</p>
            ) : block.type === 'placeholder' ? (
              <div class="project-item__marquee-media project-item__marquee-media--skeleton" style={mediaStyle(block)} aria-hidden="true"></div>
            ) : (
              <img class="project-item__marquee-media" src={withBase(block.src!)} style={mediaStyle(block)} alt="" loading="lazy" />
            )
          ))}
        </div>
      ))}
    </div>
  </div>
</a>

<script>
  // ── Desktop (≥1440): hover marquee ──
  // Scroll the strip (rAF, constant px/sec) + play only the clip under the cursor
  // (several playing previews stuttered the idle scroll). Tablet/mobile use the
  // ProjectSwiper instead, so this only runs on wide viewports.
  const SPEED = 200; // pixels per second — single knob for the marquee speed
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion && matchMedia('(min-width: 1440px)').matches) {
    document.querySelectorAll<HTMLElement>('.project-item').forEach((item) => {
      const marquee = item.querySelector<HTMLElement>('.project-item__marquee');
      const inner = item.querySelector<HTMLElement>('.project-item__marquee-inner');
      const track = item.querySelector('.project-item__marquee-track');
      if (!marquee || !inner || !track) return;

      // Scroll the strip (rAF; constant px/sec; wrap at one track-width = seamless).
      let rafId = 0, x = 0, prev = 0, startedAt = 0, wrap = 0;
      const frame = (t: number) => {
        if (!startedAt) { startedAt = t; prev = t; }
        const dt = Math.min((t - prev) / 1000, 0.05); // cap so a stalled frame can't jump the strip
        prev = t;
        if (!wrap) wrap = track.getBoundingClientRect().width;
        if (t - startedAt >= 100) { x += SPEED * dt; if (wrap) x %= wrap; }
        inner.style.transform = `translateX(${-x}px)`;
        rafId = requestAnimationFrame(frame);
      };

      // Play ONLY the clip directly under the cursor.
      const videos = [...item.querySelectorAll<HTMLVideoElement>('.project-item__marquee video')];
      let hovered = false, mx = -1, my = -1, pickTimer = 0, preloaded = false;
      const playUnderCursor = () => {
        if (!hovered) return;
        let target: HTMLVideoElement | null = null;
        for (const v of videos) {
          const r = v.getBoundingClientRect();
          if (mx >= r.left && mx <= r.right && my >= r.top && my <= r.bottom) { target = v; break; }
        }
        for (const v of videos) {
          if (v === target) { const p = v.play(); if (p) p.catch(() => {}); } else v.pause();
        }
      };

      item.addEventListener('pointermove', (e) => { mx = e.clientX; my = e.clientY; playUnderCursor(); });
      item.addEventListener('pointerenter', (e) => {
        hovered = true; mx = e.clientX; my = e.clientY;
        // Start downloading every clip the moment the project is hovered, so they're
        // ready as the strip scrolls (playback stays single-clip, under the cursor).
        if (!preloaded) {
          preloaded = true;
          videos.forEach((v) => { v.preload = 'auto'; v.load(); });
        }
        if (!rafId) { x = 0; prev = 0; startedAt = 0; wrap = track.getBoundingClientRect().width; rafId = requestAnimationFrame(frame); }
        pickTimer = window.setInterval(playUnderCursor, 80); // re-check as the strip scrolls under a still cursor
        playUnderCursor();
      });
      item.addEventListener('pointerleave', () => {
        hovered = false;
        clearInterval(pickTimer);
        videos.forEach((v) => v.pause());
        cancelAnimationFrame(rafId); rafId = 0;
        inner.style.transform = '';
      });
    });
  }
</script>

<style>
  .project-item {
    display: block;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background-color 0.25s;
    /* full-bleed separator above each project (and between them) */
    border-top: 1.5px solid var(--color-text);
  }

  /* Desktop hover: keep the main dark background, the marquee shows white text/media */
  .project-item:hover {
    background-color: var(--color-bg);
  }

  /* Static index + title aligned to the grid; the marquee stays full-bleed. */
  .project-item__content {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    height: 20rem;
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .project-item__head {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    min-width: 0;
  }

  .project-item__index {
    font-family: var(--font-mono);
    font-weight: 300;
    font-size: 1.25rem;
    line-height: 1.5;
    margin-top: 5.125rem;
    transition: opacity 0.15s;
  }

  .project-item__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15.625rem;
    line-height: 0.8;
    margin-top: 1.875rem;
    text-transform: lowercase;
    transition: opacity 0.15s;
  }

  /* "view project →" caption under the swiper (lives in the media slot, so it's
     hidden on desktop with it and shown below 1440). */
  .project-item__cta {
    display: block;
    margin-top: 1.875rem;
    text-align: center;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .project-item:hover .project-item__index,
  .project-item:hover .project-item__title {
    opacity: 0;
  }

  /* Swiper slot — hidden on desktop (the marquee handles hover there) */
  .project-item__media {
    display: none;
  }

  /* Marquee overlay */
  .project-item__marquee {
    position: absolute;
    inset: 0;
    padding-block: 1.125rem;
    overflow: hidden;
    display: none;
    pointer-events: none;
    container-type: inline-size; /* 100cqw = row width (no scrollbar), matches the .container math */
  }

  .project-item:hover .project-item__marquee {
    display: block;
  }

  /* Two identical tracks side by side, scrolling in lockstep for a seamless loop */
  .project-item__marquee-inner {
    display: flex;
    height: 100%;
  }

  .project-item__marquee-track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    height: 100%;
    gap: var(--gap-gallery);
    /* Leading gap = page text's left edge (same math as .container; 100cqw = row width).
       It lives INSIDE the looped period, so it recurs identically at every seam ->
       the loop is flash-free, and the first item starts exactly on the page grid. */
    padding-left: max(var(--page-padding), calc((100cqw - var(--grid-max)) / 2 + var(--page-padding)));
  }

  /* Promote the moving strip while hovered so its per-frame transform composites on the GPU. */
  .project-item:hover .project-item__marquee-inner {
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-item__marquee-media--skeleton {
      animation: none;
    }
  }

  /* Number + name pair — same offsets as the static .project-item__content */
  .project-item__marquee-name {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: -1.125rem; /* cancel .project-item__marquee padding-block so offsets are from the row top */
  }

  .project-item__marquee-index {
    font-family: var(--font-mono);
    font-weight: 300;
    font-size: 1.25rem;
    line-height: 1.5;
    margin-top: 5.125rem;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .project-item__marquee-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15.625rem;
    line-height: 0.8;
    margin-top: 1.875rem;
    color: var(--color-text);
    flex-shrink: 0;
    white-space: nowrap;
    text-transform: lowercase;
  }

  .project-item__marquee-media {
    display: block;
    height: 100%;
    aspect-ratio: 3 / 4;
    width: auto;
    object-fit: cover;
    flex-shrink: 0;
    background-color: var(--color-placeholder);
  }

  .project-item__marquee-media--skeleton {
    background-image: linear-gradient(100deg, transparent 40%, rgba(255, 255, 255, 0.07) 50%, transparent 60%);
    background-repeat: no-repeat;
    background-size: 200% 100%;
    animation: marquee-skeleton 1.4s linear infinite;
  }

  @keyframes marquee-skeleton {
    from { background-position: 150% 0; }
    to   { background-position: -150% 0; }
  }

  .project-item__marquee-desc {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    line-height: 1.5;
    width: 28.75rem;
    margin-inline: 1.875rem;
    color: var(--color-text);
    flex-shrink: 0;
  }

  /* ── Tablet & mobile (<1440): swiper replaces the hover marquee ── */
  @media (max-width: 1439px) {
    .project-item,
    .project-item:hover {
      background-color: transparent;
    }

    .project-item:hover .project-item__index,
    .project-item:hover .project-item__title {
      opacity: 1;
    }

    .project-item__marquee {
      display: none !important;
    }

    .project-item__content {
      height: auto;
      align-items: flex-start; /* title pinned to the top of the row, not centred */
      gap: 2.5rem;
      padding-block: 2.5rem;
    }

    .project-item__head {
      /* fixed share so the swiper starts at the same x across every row */
      flex: 0 0 45%;
      align-items: flex-start;
      gap: 0.5rem;
      --wi-title: 5.625rem; /* title size per breakpoint; also drives the index's top offset */
    }

    .project-item__index {
      /* push the number down so its top edge meets the title's text top */
      margin-top: calc(var(--wi-title) * 0.26);
      align-self: flex-start;
      line-height: 1;
      font-size: 0.875rem;
    }

    .project-item__title {
      margin-top: 0;
      font-size: var(--wi-title);
      line-height: 0.9;
    }

    .project-item__media {
      display: block;
      flex: 1 1 0;
      min-width: 0;
    }
  }

  /* Font size steps down at 1024 */
  @media (max-width: 1023px) {
    .project-item__head {
      --wi-title: 4.375rem;
    }
  }

  /* <900: swiper drops under the title (900 itself stays side-by-side, per the mock) */
  @media (max-width: 899px) {
    .project-item__content {
      flex-direction: column;
      align-items: stretch;
      gap: 1.25rem;
      padding-block: 1.875rem;
    }

    .project-item__head {
      flex: none;
      --wi-title: clamp(2.75rem, 13vw, 3.75rem);
    }

    .project-item__title {
      line-height: 1;
    }

    .project-item__media {
      flex: none;
      width: 100%;
    }
  }
</style>
