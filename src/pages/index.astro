---
import Layout from '../layouts/Layout.astro';
import WorkItem from '../components/WorkItem.astro';
import gisou from '../content/works/gisou.json';
import omut from '../content/works/omut.json';
import blanc from '../content/works/blanc.json';
// balmain is kept in content but hidden for now (not enough material yet)

type Work = typeof omut & { hoverImages: string[] };
const works = [gisou, omut, blanc] as Work[];
---

<Layout title="Arina Makhova — Works">
  <section class="works">
    {works.map((work) => (
      <WorkItem
        slug={work.slug}
        index={work.index}
        title={work.title}
        cover={work.cover}
        hoverImages={work.hoverImages}
        description={work.description}
      />
    ))}
  </section>
</Layout>

<style>
  .works {
    padding-top: var(--nav-height);
    /* line below the last project (separators above each project live in WorkItem) */
    border-bottom: 1.5px solid var(--color-text);
  }
</style>
