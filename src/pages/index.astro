---
import Layout from '../layouts/Layout.astro';
import WorkItem from '../components/WorkItem.astro';
import gisou from '../content/works/gisou.json';
import omut from '../content/works/omut.json';
import lancel from '../content/works/lancel.json';
// balmain is kept in content but hidden for now (not enough material yet)

const works = [gisou, omut, lancel];
---

<Layout
  title="Arina Makhova — Works"
  preloadFonts={['/fonts/Sharphy-SemiBold.woff2', '/fonts/silkamono-regular-webfont.woff2', '/fonts/silkamono-light-webfont.woff2']}
>
  <section class="works">
    {works.map((work) => (
      <WorkItem
        slug={work.slug}
        index={work.index}
        title={work.title}
        description={work.description}
        marquee={work.marquee}
        swiper={work.swiper}
      />
    ))}
  </section>
</Layout>

<style>
  .works {
    padding-top: var(--nav-height);
    /* line below the last project (separators above each project live in WorkItem) */
    border-bottom: 1.5px solid var(--color-text);
  }
</style>
