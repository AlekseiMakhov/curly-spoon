---
import Layout from '../layouts/Layout.astro';
import ProjectItem from '../components/ProjectItem.astro';
import gisou from '../content/projects/gisou.json';
import omut from '../content/projects/omut.json';
import lancel from '../content/projects/lancel.json';
// balmain is kept in content but hidden for now (not enough material yet)

const projects = [gisou, omut, lancel];
---

<Layout
  title="Arina Makhova — Projects"
  description="Selected projects by Arina Makhova — a multidisciplinary designer blending 3D and AI across beauty, jewelry, fashion, and consumer tech. Featuring projects for Gisou, Omut, and Lancel."
  preloadFonts={['/fonts/Sharphy-SemiBold.woff2', '/fonts/silkamono-regular-webfont.woff2', '/fonts/silkamono-light-webfont.woff2']}
>
  <section class="projects">
    {projects.map((project, i) => (
      <ProjectItem
        slug={project.slug}
        index={project.index}
        title={project.title}
        description={project.description}
        marquee={project.marquee}
        swiper={project.swiper}
        priority={i === 0}
      />
    ))}
  </section>
</Layout>

<style>
  .projects {
    padding-top: var(--nav-height);
    /* line below the last project (separators above each project live in ProjectItem) */
    border-bottom: 1.5px solid var(--color-text);
  }
</style>
