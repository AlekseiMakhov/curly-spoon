---
import Layout from '../../layouts/Layout.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';
import ProjectHeader from '../../components/ProjectHeader.astro';
import ProjectFooter from '../../components/ProjectFooter.astro';
import gisou from '../../content/projects/gisou.json';
import omut from '../../content/projects/omut.json';
import lancel from '../../content/projects/lancel.json';
// balmain is kept in content but hidden for now (not enough material yet)

export function getStaticPaths() {
  return [
    { params: { slug: 'gisou' } },
    { params: { slug: 'omut' } },
    { params: { slug: 'lancel' } },
  ];
}

// Galleries differ in shape per project (R2 vs legacy), so keep this loose.
const projectsMap: Record<string, any> = { gisou, omut, lancel };
const { slug } = Astro.params;
const project = projectsMap[slug];
const nextProject = projectsMap[project.next];
---

<Layout
  title={`${project.title} — Arina Makhova`}
  description={project.description}
  ogImage={project.cover}
  ogType="article"
  preloadFonts={['/fonts/Sharphy-SemiBold.woff2', '/fonts/silkamono-regular-webfont.woff2']}
>
  <article class="project">
    <ProjectHeader index={project.index} title={project.title} description={project.description} />

    <div class="project__gallery">
      <ProjectGallery slug={slug} items={project.gallery} />
    </div>

    <ProjectFooter nextSlug={nextProject.slug} nextTitle={nextProject.title} />
  </article>
</Layout>

<style>
  .project {
    padding-top: var(--nav-height);
  }

  .project__gallery {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding: 0 var(--page-padding);
  }
</style>
