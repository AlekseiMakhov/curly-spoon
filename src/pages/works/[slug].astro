---
import Layout from '../../layouts/Layout.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';
import ProjectHeader from '../../components/ProjectHeader.astro';
import ProjectFooter from '../../components/ProjectFooter.astro';
import gisou from '../../content/works/gisou.json';
import omut from '../../content/works/omut.json';
import blanc from '../../content/works/blanc.json';
// balmain is kept in content but hidden for now (not enough material yet)

export function getStaticPaths() {
  return [
    { params: { slug: 'gisou' } },
    { params: { slug: 'omut' } },
    { params: { slug: 'blanc' } },
  ];
}

const worksMap: Record<string, typeof gisou> = { gisou, omut, blanc };
const { slug } = Astro.params;
const work = worksMap[slug];
const nextWork = worksMap[work.next];
---

<Layout
  title={`${work.title} — Arina Makhova`}
  preloadFonts={['/fonts/Sharphy-SemiBold.woff2', '/fonts/silkamono-regular-webfont.woff2']}
>
  <article class="project">
    <ProjectHeader index={work.index} title={work.title} description={work.description} />

    <div class="project__gallery">
      <ProjectGallery items={work.gallery} />
    </div>

    <ProjectFooter nextSlug={nextWork.slug} nextTitle={nextWork.title} />
  </article>
</Layout>

<style>
  .project {
    padding-top: var(--nav-height);
  }

  .project__gallery {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding: 0 var(--page-padding);
  }
</style>
