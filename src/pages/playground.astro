---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Playground — Arina Makhova"
  description="A space for experiments and works in progress by Arina Makhova."
  noindex
  preloadFonts={['/fonts/Sharphy-Regular.woff2', '/fonts/silkamono-regular-webfont.woff2']}
>
  <section class="playground">
    {/* Empty for now */}
  </section>
</Layout>

<style>
  /* Same grid container as the rest of the site */
  .playground {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    padding-top: calc(var(--nav-height) + 100px);
    min-height: 100vh;
  }

  @media (max-width: 1366px) {
    .playground {
      padding-top: calc(var(--nav-height) + 50px);
    }
  }
</style>
