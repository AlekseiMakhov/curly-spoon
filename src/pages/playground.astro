---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProjectHeader from '../components/ProjectHeader.astro';
import PlaygroundCarousel from '../components/PlaygroundCarousel.astro';
import { MEDIA_BASE } from '../consts';

// Playground media lives on R2 next to the project folders, under `playground/`,
// in numbered folders (001, 002, …) each holding numbered images (01.jpg, 02.jpg, …).
// The page discovers them at runtime (no config) — drop new folders/images into the
// bucket and they appear on next load, no redeploy. See the client script below.
const playgroundBase = `${MEDIA_BASE}/playground`;

const description =
  'A collection of personal experiments exploring materials, textures, light, and form through 3D and AI-driven workflows.';
// Soft hyphen: the title breaks as "play-/ground" only when it doesn't fit (portrait).
const title = 'Play­ground';
---

<Layout
  title="Playground — Arina Makhova"
  description={description}
  preloadFonts={['/fonts/Sharphy-SemiBold.woff2', '/fonts/silkamono-regular-webfont.woff2']}
>
  <div class="pg-intro">
    <ProjectHeader title={title} description={description} />
  </div>

  <section class="playground">
    <div class="pg-grid" data-pg-grid data-base={playgroundBase}></div>
  </section>

  <SiteFooter />
</Layout>

{/* Registers the <pg-carousel> custom element + its styles (renders no markup) */}
<PlaygroundCarousel />

<script>
  // ── Lazy, row-by-row discovery (virtual scroll) ──
  // Skeleton cards fill the viewport immediately; each row is then probed + loaded a
  // full row at a time (its folders in parallel via Promise.allSettled) as the grid
  // bottom nears the viewport. Folders are sequential, so the first missing one ends
  // the list (and trims the leftover skeletons). Each card is a <pg-carousel> that
  // loads its own folder — see PlaygroundCarousel.astro.
  const PADDING = 300; // px of lookahead for skeleton fill + prefetch
  const grid = document.querySelector<HTMLElement>('[data-pg-grid]');

  if (grid) {
    // ?pgbase=… overrides the base (handy for local testing against /media/playground).
    const override = new URLSearchParams(location.search).get('pgbase');
    const base = (override ?? grid.dataset.base ?? '').replace(/\/$/, '');
    const colsNow = () => (window.innerWidth <= 479 ? 1 : window.innerWidth <= 1439 ? 2 : 3);

    type Card = HTMLElement & { load(): Promise<boolean> };

    const sentinel = document.createElement('div');
    sentinel.className = 'pg-sentinel';
    grid.appendChild(sentinel);

    let nextFolder = 1;
    let ended = false;
    let pumping = false;
    const queue: Card[][] = []; // skeleton rows waiting to be loaded

    const makeCard = (folder: number): Card => {
      const el = document.createElement('pg-carousel') as Card;
      el.dataset.folder = String(folder);
      el.dataset.base = base;
      grid.insertBefore(el, sentinel);
      return el;
    };

    const sentinelNearViewport = () =>
      sentinel.getBoundingClientRect().top <= window.innerHeight + PADDING;

    // Create skeleton rows synchronously until they fill the viewport (+lookahead).
    const ensureSkeletons = () => {
      for (let guard = 0; !ended && guard < 100 && sentinelNearViewport(); guard++) {
        const cols = colsNow();
        queue.push(Array.from({ length: cols }, (_, k) => makeCard(nextFolder + k)));
        nextFolder += cols;
      }
    };

    // Load queued rows in order — each row's folders in parallel; stop at the first gap.
    const pump = async () => {
      if (pumping) return;
      pumping = true;
      while (queue.length) {
        const row = queue.shift()!;
        if (ended) {
          row.forEach((card) => card.remove());
          continue;
        }
        const results = await Promise.allSettled(row.map((card) => card.load()));
        for (let k = 0; k < row.length; k++) {
          const result = results[k];
          const exists = result.status === 'fulfilled' && result.value;
          if (!exists) {
            ended = true;
            for (let j = k; j < row.length; j++) row[j].remove();
            break;
          }
        }
      }
      pumping = false;
      if (ended) {
        io.disconnect();
        sentinel.remove();
      }
    };

    const tick = () => {
      if (ended) return;
      ensureSkeletons();
      pump();
    };

    const io = new IntersectionObserver(tick, { rootMargin: `${PADDING}px 0px` });
    io.observe(sentinel);
    tick();
  }
</script>

<style is:global>
  /* Clears the fixed nav; the header below adds its own top gap (like project pages). */
  .pg-intro {
    padding-top: var(--nav-height);
  }

  /* 3 per row (desktop) / 2 (tablet + landscape mobile) / 1 (portrait mobile) */
  .pg-grid {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--grid-gutter);
  }

  /* Full-width zero-height marker: when it nears the viewport, the next row loads */
  .pg-sentinel {
    grid-column: 1 / -1;
    height: 1px;
  }

  @media (max-width: 1439px) {
    .pg-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Mobile: bigger gap between carousels */
  @media (max-width: 900px) {
    .pg-grid {
      gap: 1.875rem; /* 30px */
    }
  }

  @media (max-width: 479px) {
    .pg-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
