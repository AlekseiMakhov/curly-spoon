---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { MEDIA_BASE } from '../consts';

// Playground media lives on R2 next to the project folders, under `playground/`,
// in numbered folders (001, 002, …) each holding numbered images (1.jpg, 2.jpg, …).
// The page DISCOVERS them at runtime (no config), so new folders/images can be
// dropped into the bucket without redeploying the site. See the client script.
const playgroundBase = `${MEDIA_BASE}/playground`;
---

<Layout
  title="Playground — Arina Makhova"
  description="A space for experiments and works in progress by Arina Makhova."
  preloadFonts={['/fonts/Sharphy-Regular.woff2', '/fonts/silkamono-regular-webfont.woff2']}
>
  <section class="playground">
    <div class="pg-grid" data-pg-grid data-base={playgroundBase}></div>
  </section>

  <SiteFooter />
</Layout>

<script>
  // ── Runtime discovery + carousels ──
  // No build-time config: we probe R2 by the numeric convention
  //   <base>/<NNN>/<i>.<ext>   (NNN = 001.., i = 1.., ext tried in order)
  // and stop at the first gap. Drop new folders/images into the bucket and they
  // appear on next load — no redeploy. Existence is tested with `new Image()`
  // (cross-origin friendly; doubles as a preload for display).
  const grid = document.querySelector<HTMLElement>('[data-pg-grid]');
  if (grid) {
    // ?pgbase=… overrides the base (handy for local testing against /media/playground).
    const override = new URLSearchParams(location.search).get('pgbase');
    const BASE = (override ?? grid.dataset.base ?? '').replace(/\/$/, '');

    const EXTS = ['jpg', 'jpeg', 'png', 'webp'];
    const MAX_FOLDERS = 200;
    const MAX_IMAGES = 200;
    const SWIPE_MIN = 40;
    const DURATION = matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 500;
    const pad = (n: number) => String(n).padStart(3, '0');

    const loadImage = (url: string) =>
      new Promise<boolean>((res) => {
        const im = new Image();
        im.onload = () => res(true);
        im.onerror = () => res(false);
        im.src = url;
      });

    // First existing URL for image `i` in folder `f`, trying each extension; else null.
    const findImage = async (f: number, i: number) => {
      for (const ext of EXTS) {
        const url = `${BASE}/${pad(f)}/${i}.${ext}`;
        if (await loadImage(url)) return url;
      }
      return null;
    };

    // Build one carousel element and wire its interactions (only if >1 image).
    const buildCarousel = (images: string[]) => {
      const n = images.length;
      const root = document.createElement('div');
      root.className = 'pgc';

      const vp = document.createElement('div');
      vp.className = 'pgc__viewport';
      images.forEach((src, i) => {
        const slide = document.createElement('div');
        slide.className = 'pgc__slide' + (i === 0 ? ' is-active' : '');
        const img = document.createElement('img');
        img.className = 'pgc__img';
        img.src = src;
        img.alt = '';
        img.loading = 'lazy';
        img.decoding = 'async';
        img.draggable = false;
        slide.appendChild(img);
        vp.appendChild(slide);
      });
      root.appendChild(vp);

      if (n <= 1) return root; // single image: no dots, no interaction

      const dots = document.createElement('div');
      dots.className = 'pgc__dots';
      images.forEach((_, i) => {
        const d = document.createElement('span');
        d.className = 'pgc__dot' + (i === 0 ? ' is-active' : '');
        dots.appendChild(d);
      });
      root.appendChild(dots);

      const slides = [...root.querySelectorAll<HTMLElement>('.pgc__slide')];
      const dotEls = [...root.querySelectorAll<HTMLElement>('.pgc__dot')];
      let active = 0;
      let animating = false;
      vp.style.cursor = 'pointer';

      // Advance to the next image: it slides IN FROM THE LEFT while the current
      // one exits to the right. Looping. Active dot fades across (CSS transition).
      const go = () => {
        if (animating) return;
        const cur = active;
        const nxt = (active + 1) % n;
        if (cur === nxt) return;
        animating = true;

        const c = slides[cur];
        const x = slides[nxt];
        x.classList.add('is-entering');
        x.style.transition = 'none';
        x.style.transform = 'translateX(-100%)';
        c.style.transition = 'none';
        c.style.transform = 'translateX(0)';
        void root.offsetWidth; // reflow so the start positions take effect

        const tr = `transform ${DURATION}ms cubic-bezier(0.65, 0, 0.35, 1)`;
        x.style.transition = tr;
        c.style.transition = tr;
        x.style.transform = 'translateX(0)';
        c.style.transform = 'translateX(100%)';
        dotEls[cur].classList.remove('is-active');
        dotEls[nxt].classList.add('is-active');

        const done = () => {
          x.removeEventListener('transitionend', done);
          c.classList.remove('is-active');
          c.style.transition = '';
          c.style.transform = '';
          x.classList.remove('is-entering');
          x.classList.add('is-active');
          x.style.transition = '';
          x.style.transform = '';
          active = nxt;
          animating = false;
        };
        if (DURATION === 0) done();
        else x.addEventListener('transitionend', done);
      };

      vp.addEventListener('click', go);

      // Swipe (touch) — any horizontal swipe advances, like a click.
      let sx = 0, sy = 0, tracking = false;
      vp.addEventListener('touchstart', (e) => {
        sx = e.touches[0].clientX; sy = e.touches[0].clientY; tracking = true;
      }, { passive: true });
      vp.addEventListener('touchend', (e) => {
        if (!tracking) return;
        tracking = false;
        const dx = e.changedTouches[0].clientX - sx;
        const dy = e.changedTouches[0].clientY - sy;
        if (Math.abs(dx) >= SWIPE_MIN && Math.abs(dx) > Math.abs(dy)) go();
      }, { passive: true });

      return root;
    };

    // Walk folders 001.. ; within each, images 1.. — stop at the first gap.
    // Render each carousel as soon as its folder is fully discovered (progressive).
    (async () => {
      for (let f = 1; f <= MAX_FOLDERS; f++) {
        const first = await findImage(f, 1);
        if (!first) break; // no folder f -> done
        const images = [first];
        for (let i = 2; i <= MAX_IMAGES; i++) {
          const u = await findImage(f, i);
          if (!u) break;
          images.push(u);
        }
        grid.appendChild(buildCarousel(images));
      }
    })();
  }
</script>

<style is:global>
  /* Carousels are created at runtime, so these styles must be global
     (Astro's scoped styles only apply to build-time elements). */
  .playground {
    padding-top: calc(var(--nav-height) + 100px);
    padding-bottom: 100px;
    min-height: 60vh;
  }

  /* 3 per row (desktop) / 2 (tablet + landscape mobile) / 1 (portrait mobile) */
  .pg-grid {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--grid-gutter);
  }

  @media (max-width: 1439px) {
    .pg-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .playground {
      padding-top: calc(var(--nav-height) + 50px);
    }
  }

  @media (max-width: 479px) {
    .pg-grid {
      grid-template-columns: 1fr;
    }
  }

  /* One image visible at a time, in a 3/4 frame. */
  .pgc {
    width: 100%;
  }

  .pgc__viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: var(--color-placeholder);
    touch-action: pan-y; /* page scrolls vertically; horizontal = our swipe */
  }

  .pgc__slide {
    position: absolute;
    inset: 0;
    display: none;
    will-change: transform;
  }

  .pgc__slide.is-active,
  .pgc__slide.is-entering {
    display: block;
  }

  .pgc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    user-select: none;
  }

  /* Dots — one per image; active is solid white, others dimmed (fades across). */
  .pgc__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 14px;
  }

  .pgc__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-text);
    opacity: 0.35;
    transition: opacity 0.4s;
  }

  .pgc__dot.is-active {
    opacity: 1;
  }
</style>
