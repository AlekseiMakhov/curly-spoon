---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="About — Arina Makhova"
  preloadFonts={['/fonts/Sharphy-Regular.woff2', '/fonts/silkamono-regular-webfont.woff2']}
>
  <article class="about">
    <div class="about__texts">
      <p class="about__text">I’m a multidisciplinary designer with a background in graphic design, now focused on 3D, AI, and motion.</p>
      <p class="about__text">I’m fascinated by the intersection of art, design, and emerging technologies, constantly exploring new tools, workflows, and creative possibilities. My work combines the precision and control of 3D with the speed, experimentation, and creative potential of AI.</p>
      <p class="about__text">I’m particularly drawn to projects that translate products, objects, and ideas into visual experiences, with a focus on beauty, jewelry, fashion, and consumer tech.</p>
      <p class="about__text">I’m always open to new collaborations and creative projects. Feel free to get in touch if you’d like to collaborate, discuss a project, or connect professionally. You can reach me via email or through my social channels.</p>
    </div>
  </article>

  <SiteFooter />
</Layout>

<style>
  /* Same grid container as the rest of the site */
  .about {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    padding-top: calc(var(--nav-height) + 100px); /* 100 below the header */
  }

  .about__texts {
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  .about__text {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 64px;
    line-height: 1.4;
  }

  /* Tablet (900–1366) */
  @media (max-width: 1366px) {
    .about {
      padding-top: calc(var(--nav-height) + 50px);
    }

    .about__texts {
      gap: 40px;
    }

    .about__text {
      font-size: 40px;
    }
  }

  /* Mobile (<900) */
  @media (max-width: 900px) {
    .about__texts {
      gap: 30px;
    }

    .about__text {
      font-size: 30px;
    }
  }
</style>
